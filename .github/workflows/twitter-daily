name: Daily Trade Tweet

on:
  schedule:
    - cron: '10 21 * * 1-5'
  workflow_dispatch: {}

jobs:
  tweet:
    runs-on: ubuntu-latest

    steps:
      - name: Install dependencies
        run: |
          pip install requests requests-oauthlib

      - name: Post tweet
        env:
          BASE44_API_KEY: ${{ secrets.BASE44_API_KEY }}
          API_KEY: ${{ secrets.TWITTER_API_KEY }}
          API_SECRET: ${{ secrets.TWITTER_API_SECRET }}
          ACCESS_TOKEN: ${{ secrets.TWITTER_ACCESS_TOKEN }}
          ACCESS_SECRET: ${{ secrets.TWITTER_ACCESS_SECRET }}
        run: |
          python3 << 'PY'
          import os
          import requests
          from datetime import datetime
          from requests_oauthlib import OAuth1

          API_KEY=os.environ["API_KEY"]
          API_SECRET=os.environ["API_SECRET"]
          ACCESS_TOKEN=os.environ["ACCESS_TOKEN"]
          ACCESS_SECRET=os.environ["ACCESS_SECRET"]

          BASE44=os.environ["BASE44_API_KEY"]

          # fetch trades
          r = requests.get(
              "https://app.base44.com/api/apps/6921d8e3ab33f86e081375a1/entities/Trade?limit=999999",
              headers={"api_key": BASE44}
          )

          data=r.json()

          if "items" in data:
              trades=data["items"]
          else:
              trades=data

          today=datetime.utcnow().strftime("%Y-%m-%d")

          tweets=[]

          for t in trades:

              open_date=str(t.get("open_date","")).split("T")[0]
              close_date=str(t.get("close_date","")).split("T")[0]

              if open_date!=today and close_date!=today:
                  continue

              direction=t.get("direction")
              ticker=t.get("ticker")
              qty=t.get("quantity")
              type=t.get("type")
              strike=t.get("strike_price")
              strike2=t.get("strike_price_2")

              closed=bool(close_date)

              if direction=="BUY" and not closed:
                  prefix="Buy to Open"
              elif direction=="BUY" and closed:
                  prefix="Sell to Close"
              elif direction=="SELL" and not closed:
                  prefix="Sell to Open"
              else:
                  prefix="Buy to Close"

              if closed:
                  profit=t.get("profit_loss",0)
                  line=f"{prefix} {qty} {ticker} {type} {strike}/{strike2} → ${profit} profit"
              else:
                  price=t.get("open_price")
                  exp=t.get("expiration_date")
                  line=f"{prefix} {qty} {ticker} {type} {strike}/{strike2} @{price} Exp {exp}"

              tweets.append(line)

          if not tweets:
              print("No trades today")
              exit()

          tweet="\n".join(tweets)

          auth=OAuth1(API_KEY,API_SECRET,ACCESS_TOKEN,ACCESS_SECRET)

          requests.post(
              "https://api.twitter.com/2/tweets",
              json={"text":tweet[:270]},
              auth=auth
          )

          print("Tweet sent")
          PY
